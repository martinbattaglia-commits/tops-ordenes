# =========================================================================
# TOPS Órdenes — Variables de entorno
# Copiá este archivo como `.env.local` y completá los valores reales.
# NUNCA commitees `.env.local` al repo.
# =========================================================================

# ---- Supabase (obligatorio) ---------------------------------------------
# Console: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
# Solo backend (server actions / route handlers). NO exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ---- Email transaccional (opcional pero recomendado) --------------------
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# Remitente verificado en Resend (debe coincidir con un dominio verificado)
RESEND_FROM_EMAIL="TOPS Compras <ordenes@logisticatops.com>"

# Reglas de envío
EMAIL_ADMIN_RUTH=ruth@logisticatops.com
EMAIL_ADMIN_JOSELUIS=joseluis@logisticatops.com
EMAIL_DEPOT_MAGALDI=juancarlos@logisticatops.com
EMAIL_DEPOT_LUJAN=despachos@logisticatops.com

# ---- App ----------------------------------------------------------------
# Usado para construir URLs públicas (QR del comprobante, links del email).
NEXT_PUBLIC_APP_URL=https://nexus.logisticatops.com

# Modo demo: si está en "1" arranca con datos mock y no requiere Supabase.
# Útil para evaluar la UI antes de aprovisionar la base.
NEXT_PUBLIC_DEMO_MODE=0

# ---- Clientify CRM (opcional, módulo Servicios) -------------------------
CLIENTIFY_API_KEY=
CLIENTIFY_BASE_URL=https://api.clientify.net/v1

# ---- ARCA / Facturación Electrónica (ex-AFIP, WSFEv1) -------------------
# Ambiente por defecto. La fuente de verdad real es fiscal_config.ambiente
# (administrable desde /settings/fiscal). SANDBOX usa el Mock ARCA Service.
ARCA_AMBIENTE=SANDBOX
# Certificado X.509 + clave privada para WSAA (montados en el host).
# La clave privada NUNCA va al repo ni a la base de datos.
ARCA_CERT_PATH=/etc/secrets/arca-cert.pem
ARCA_KEY_PATH=/etc/secrets/arca-key.pem
# Endpoints oficiales (host afip.gov.ar — no cambiar).
# Homologación: https://wswhomo.afip.gov.ar/wsfev1/service.asmx
ARCA_WSAA_URL=https://wsaa.afip.gov.ar/ws/services/LoginCms
ARCA_WSFEV1_URL=https://servicios1.afip.gov.ar/wsfev1/service.asmx

# ---- Google Drive sync (opcional, módulo Compras) -----------------------
# Service account JSON con scope drive.file. Pegar el JSON completo
# (escapado) o referenciar un secreto montado en /etc/secrets.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ---- CRM Comercial → Contratos · sync Drive (fuente de verdad operativa) -
# Carpeta(s) de CATEGORÍA de clientes bajo «… → Clientes → DOCUMENTACION CLIENTES»:
# «CLIENTES DE ANMAT» y «CLIENTES CARGAS GENERALES». Los hijos directos de cada una
# son los dossiers de cliente; el tipo de contrato (ANMAT / Cargas Generales) se
# deriva del nombre de la carpeta. Poné el/los ID(s) directos (de la URL
# drive.google.com/drive/folders/<ID>), SEPARADOS POR COMA. Las carpetas deben estar
# compartidas con la Service Account (Lector). Si se deja vacío, el motor resuelve por
# NOMBRE con CONTRATOS_DRIVE_PATH desde el root de la SA (un solo contenedor).
# Ej.: CONTRATOS_DRIVE_FOLDER_ID=19xqJ9ACeZk76_e4SnIip9z8GiPiM-gIZ,1QHBqHwhctbEGSE4kcS1JgM2CvOwqlt5W
CONTRATOS_DRIVE_FOLDER_ID=
CONTRATOS_DRIVE_PATH=Comercial/Cynthia/Clientes
# Extraer texto de los documentos durante el sync (OCR sólo si es necesario).
# Poné 0 para desactivar la extracción (más rápido / sin costo OpenAI).
CONTRATOS_SYNC_EXTRACT_TEXT=1

# ---- Compliance Cockpit (/anmat) · sync Drive (fuente documental de verdad) -
# Carpeta regulatoria «AGENCIA GUBERNAMENTAL DE CONTROL» (habilitaciones,
# certificados, ANMAT, ambiental, seguros). Preferido: ID directo de la carpeta;
# si se deja vacío, el motor resuelve por NOMBRE con COMPLIANCE_DRIVE_PATH desde
# el root de la SA. Lo dispara .github/workflows/compliance-drive-sync.yml (21:00 ART).
COMPLIANCE_DRIVE_FOLDER_ID=
COMPLIANCE_DRIVE_PATH=AGENCIA GUBERNAMENTAL DE CONTROL
# Parseo del contenido del PDF para extraer fechas (además del nombre). Off por
# defecto (1 para activar) — la extracción por nombre/metadata es suficiente.
COMPLIANCE_SYNC_EXTRACT_TEXT=0

# ---- Cron / jobs programados --------------------------------------------
# Secreto Bearer que exigen los endpoints de jobs (sync diario de Contratos,
# sync de Clientify, etc.). El scheduler (GitHub Actions) lo envía como
# `Authorization: Bearer <CRON_SECRET>`. Si se deja vacío, los endpoints quedan
# abiertos (sólo para desarrollo local).
CRON_SECRET=

# ---- OpenAI (OCR / extracción de documentos) ----------------------------
# Usado por el Centro Documental para leer facturas de proveedor (foto/PDF)
# y extraer Proveedor/CUIT/Fecha/Importe/IVA automáticamente.
# gpt-4o-mini es barato (~US$1-2/mes a 200 facturas) y suficiente.
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-4o-mini

# ---- WhatsApp Business (Meta Cloud API) — F4.4 sandbox -----------------------
# Cliente saliente + webhook inbound. En F4.4 el canal opera SOLO en sandbox.
META_WA_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
# App Secret de la app de Meta (Settings → Basic) — OBLIGATORIO para la
# verificación HMAC X-Hub-Signature-256 del webhook (fail-closed sin él).
META_WA_APP_SECRET=
# Token del handshake GET del webhook (sin default hardcodeado desde F4.4).
META_WA_WEBHOOK_VERIFY_TOKEN=
# Sandbox (D-F44-3): "0" = productivo (decisión de Dirección, F5). Default ON.
WHATSAPP_SANDBOX=1
# Números internos permitidos como destino en sandbox (E.164, coma-separados).
WHATSAPP_SANDBOX_ALLOWLIST=
# (Opcional) Secreto dedicado del endpoint /api/whatsapp/send — separa el
# privilegio "enviar mensajes" del CRON_SECRET compartido por los syncs.
# Sin esta var, el endpoint usa CRON_SECRET (fail-closed igual).
WHATSAPP_SEND_SECRET=

# ── F5.2-lite · Nexus AI Copilot (read-only) ─────────────────────────────────
# Kill-switch global FAIL-CLOSED: solo "1" habilita el Copilot.
AI_ENABLED=
# Provider del modelo: mock (default, sin red/secretos) | anthropic | openai.
# Providers reales DESHABILITADOS en F5.2-lite (D-F5-9: requiere DPA + OK Dirección).
AI_PROVIDER=mock
# Límites del piloto (D-F5-8) — defaults en código si no se setean:
# AI_LIMIT_REQUESTS_PER_DAY=40
# AI_LIMIT_TOOL_ROUNDS=4
# AI_LIMIT_OUTPUT_TOKENS=4000
# AI_LIMIT_CONTEXT_CHARS=24000
# AI_LIMIT_TURNS=10
# Provider real Anthropic (D-F5-9) — INERTE hasta ventana de activación:
# la key la carga Dirección en Netlify; jamás en repo ni en chat.
# AI_ANTHROPIC_API_KEY=
# AI_MODEL=claude-opus-4-8
# AI_DAILY_LIMIT=40
# AI_MONTHLY_BUDGET_USD=100
