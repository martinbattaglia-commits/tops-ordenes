# =========================================================================
# TOPS Órdenes — Variables de entorno
# Copiá este archivo como `.env.local` y completá los valores reales.
# NUNCA commitees `.env.local` al repo.
# =========================================================================

# ---- Supabase (obligatorio) ---------------------------------------------
# Console: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
# Solo backend (server actions / route handlers). NO exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ---- Email transaccional (opcional pero recomendado) --------------------
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# Remitente verificado en Resend (debe coincidir con un dominio verificado)
RESEND_FROM_EMAIL="TOPS Compras <ordenes@logisticatops.com>"

# Reglas de envío
EMAIL_ADMIN_RUTH=ruth@logisticatops.com
EMAIL_ADMIN_JOSELUIS=joseluis@logisticatops.com
EMAIL_DEPOT_MAGALDI=juancarlos@logisticatops.com
EMAIL_DEPOT_LUJAN=despachos@logisticatops.com

# ---- App ----------------------------------------------------------------
# Usado para construir URLs públicas (QR del comprobante, links del email).
NEXT_PUBLIC_APP_URL=https://nexus.logisticatops.com

# Modo demo: si está en "1" arranca con datos mock y no requiere Supabase.
# Útil para evaluar la UI antes de aprovisionar la base.
NEXT_PUBLIC_DEMO_MODE=0

# ---- Clientify CRM (opcional, módulo Servicios) -------------------------
CLIENTIFY_API_KEY=
CLIENTIFY_BASE_URL=https://api.clientify.net/v1

# ---- ARCA / Facturación Electrónica (ex-AFIP, WSFEv1) -------------------
# Ambiente por defecto. La fuente de verdad real es fiscal_config.ambiente
# (administrable desde /settings/fiscal). SANDBOX usa el Mock ARCA Service.
ARCA_AMBIENTE=SANDBOX
# Certificado X.509 + clave privada para WSAA (montados en el host).
# La clave privada NUNCA va al repo ni a la base de datos.
ARCA_CERT_PATH=/etc/secrets/arca-cert.pem
ARCA_KEY_PATH=/etc/secrets/arca-key.pem
# Endpoints oficiales (host afip.gov.ar — no cambiar).
# Homologación: https://wswhomo.afip.gov.ar/wsfev1/service.asmx
ARCA_WSAA_URL=https://wsaa.afip.gov.ar/ws/services/LoginCms
ARCA_WSFEV1_URL=https://servicios1.afip.gov.ar/wsfev1/service.asmx

# ---- Google Drive sync (opcional, módulo Compras) -----------------------
# Service account JSON con scope drive.file. Pegar el JSON completo
# (escapado) o referenciar un secreto montado en /etc/secrets.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
